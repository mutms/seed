{
  "name": "mutms/seed",
  "type": "project",
  "description": "Starting template for Composer-based installation of Moodle LMS with MuTMS plugins",
  "homepage": "https://github.com/mutms/seed",
  "license": "GPL-3.0-or-later",
  "require": {
    "moodle/composer-installer": "*",
    "moodle/moodle-composer-scaffold": "*",
    "moodle/moodle": "5.1.*"
  },
  "support": {
    "issues": "https://github.com/mutms/seed/issues",
    "source": "https://github.com/mutms/seed"
  },
  "config": {
    "allow-plugins": {
      "moodle/composer-installer": true,
      "moodle/moodle-composer-scaffold": true
    },
    "audit": {
      "block-insecure": false
    }
  }
}
