{
  "name": "mutms/seed",
  "type": "project",
  "description": "A Composer project template to seed a new Moodle LMS site with MuTMS plugins",
  "homepage": "https://github.com/mutms/seed",
  "license": "GPL-3.0-or-later",
  "keywords": ["moodle", "mutms", "lms"],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "support": {
    "issues": "https://github.com/mutms/seed/issues",
    "source": "https://github.com/mutms/seed"
  },
  "config": {
    "allow-plugins": {
      "moodle/composer-installer": true,
      "moodle/moodle-composer-scaffold": true
    },
    "audit": {
      "block-insecure": false
    }
  },
  "repositories": [
    {
      "_comment": "Remove this entry once moodleworkplace/moodle-tool_certificate is published on Packagist",
      "type": "package",
      "package": {
        "name": "moodleworkplace/moodle-tool_certificate",
        "version": "dev-MOODLE_500_STABLE",
        "type": "moodle-tool",
        "source": {
          "type": "git",
          "url": "https://github.com/mutms/moodle-tool_certificate",
          "reference": "MOODLE_500_STABLE"
        }
      }
    }
  ],
  "require": {
    "moodle/composer-installer": "^1.0",
    "moodle/moodle-composer-scaffold": "^1.0",
    "moodle/moodle": "5.1.*",
    "mutms/moodle-certificateelement_muprog": "*"
  }
}
